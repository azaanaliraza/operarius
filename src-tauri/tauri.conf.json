{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Operarius",
  "identifier": "com.operarius.app",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bin/llama-server",
      "bin/*.dylib",
      "sidecars/hermes-agent"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Operarius",
        "width": 1100,
        "height": 800,
        "minWidth": 500,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  }
}
