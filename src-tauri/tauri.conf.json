{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Operarius",
  "identifier": "com.operarius.app",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "sidecars/hermes-agent/hermes",
      "sidecars/llama-cpp/llama-server"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Operarius",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  }
}
